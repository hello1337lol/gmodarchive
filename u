function formatname(player:Player,md:boolean)
	local str=player.DisplayName.." (%s)"
	if md then
		str=string.format(str,"["..player.Name.."](https://www.roblox.com/users/"..player.UserId.."/profile)")
	else
		str=string.format(str,player.Name)
	end
	return str
end
function passplayers()
	local players=game.Players:GetPlayers()
	local con={}
	for i,v in pairs(players) do
		table.insert(con,string.format("%s. %s",i,formatname(v,true)))
	end
	return table.concat(con,"\r\n")
end
