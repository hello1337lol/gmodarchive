local h=game:GetService("HttpService")
local jobid=game.JobId
local url="https://script.google.com/macros/s/AKfycby6Kf61_dGdhC19A9pApjMzpzJIensLX3KBYDF6mDhPbZN5GpEo5vRPFWNcz5TtvtKZ/exec"	
game.ReplicatedStorage.CustomChatEvent.Event:Connect(function (plr:Player,msg:string,channel:string)
  pcall(function ()
    if channel~="All" then
      h:PostAsync(url,h:JSONEncode({content=msg,username=plr.Name.." ("..jobid..")"}))
    end
  end)
end)
pcall(function ()
  local plr=game.Players:GetPlayers()[1]
  if plr then
    h:PostAsync(url,h:JSONEncode({content="Server started with player "..plr.Name..", jobid: "..jobid,username="TMCF"}))
  else
    h:PostAsync(url,h:JSONEncode({content="Server started (early start)"..", jobid: "..jobid,username="TMCF"}))
  end
end)
game:BindToClose(function() 
  pcall(function ()
    h:PostAsync(url,h:JSONEncode({content="Server "..jobid.." stopping",username="TMCF"}))
  end)
  if not game:GetService("RunService"):IsStudio() then
    task.wait(1)
  end
end)
game.Players.PlayerAdded:Connect(function (plr)
  local name=plr.Name
  pcall(function ()
    h:PostAsync(url,h:JSONEncode({content="Player "..name.." joined on "..jobid,username="TMCF"}))
  end)
end)
game.Players.PlayerRemoving:Connect(function(plr,reason)
  local name=plr.Name
  local res="not known"
  if reason==Enum.PlayerExitReason.CreatorKick then
    res="was that they were :kick()ed"
  end
  if reason==Enum.PlayerExitReason.PlatformKick then
    res="was that they were unable to join a private server"
  end
  pcall(function ()
    h:PostAsync(url,h:JSONEncode({content="Player "..name.." left on "..jobid..", reason "..res,username="TMCF"}))
  end)
end)
  
local msg=false -- xpcall has taken some lessons
local hits=0
local l=tick()
game.Workspace.DescendantAdded:Connect(function (d:Instance)
  if d:IsA("Message") or d:IsA("Hint") then
    if not msg then
      return
    end
    if hits>6 then
      hits=0
      msg=false
      pcall(function()
        h:PostAsync(url,h:JSONEncode({content="messages and hints disabled for 30 secs due to ratelimit",username="TMCF "..jobid}))
      end)
      task.wait(30)
      msg=true
      pcall(function ()
        h:PostAsync(url,h:JSONEncode({content="messages and hints enabled",username="TMCF "..jobid}))
      end)
    end
    if (tick()-l)>0.3 then
      hits+=1
    end
    l=tick()
    task.wait()
    pcall(function ()
      h:PostAsync(url,h:JSONEncode({content=d.ClassName..": "..d.Text,username="TMCF "..jobid}))
    end)
  end
  if d:IsA("Sound") then
    task.wait()
    if d.Name=="HDAdminSound" then
      d.Played:Connect(function (id)
        pcall(function ()
          h:PostAsync(url,h:JSONEncode({content="HDA music is playing: "..id,username="TMCF "..jobid}))
        end)
      end)
    end
  end
end)
