local nomerge=0
function message(content,username,avatarid)
	if nomerge>5 then
		nomerge=0
	else
		nomerge+=1
	end
	pcall(function ()
		devprint(username)
		devprint(content)
		h:PostAsync(url,h:JSONEncode({content=content,username=username..string.rep(" ",nomerge),avatar_url=avatarid,flags=4}))
	end)
end
local thumbnails:{[number]:string}={}
function getthumbnailurl(userid:number)
	local imgurl=""
	if thumbnails[userid] then
		devprint("using cached thumbnail url")
		imgurl=thumbnails[userid]
	else
		devprint("no cached thumbnail url found! making one..")
		local url="https://thumbnails.roproxy.com/v1/users/avatar-headshot?userIds="..userid.."&includeBackground=true&size=75x75&format=Png&isCircular=false"
		local json=h:JSONDecode(h:GetAsync(url))
		local image:string=json["data"][1]["imageUrl"]
		thumbnails[userid]=image
		devprint("cached new thumbnail url")
		imgurl=image
	end
	return imgurl
end
